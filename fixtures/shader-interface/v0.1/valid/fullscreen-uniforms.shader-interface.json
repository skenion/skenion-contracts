{
  "schema": "skenion.shader.interface",
  "schemaVersion": "0.1.0",
  "language": "wgsl",
  "uniforms": [
    {
      "id": "speed",
      "label": "Speed",
      "type": {
        "flow": "value",
        "dataKind": "number.f32",
        "range": {
          "min": 0,
          "max": 2,
          "step": 0.01
        }
      },
      "default": 0.5,
      "required": false
    },
    {
      "id": "enabled",
      "label": "Enabled",
      "type": {
        "flow": "value",
        "dataKind": "boolean"
      },
      "default": true,
      "required": false
    },
    {
      "id": "iterations",
      "label": "Iterations",
      "type": {
        "flow": "value",
        "dataKind": "number.i32"
      },
      "default": 8,
      "required": false
    },
    {
      "id": "tint",
      "label": "Tint",
      "type": {
        "flow": "value",
        "dataKind": "color.rgba"
      },
      "default": [1, 0.2, 0.1, 1],
      "required": false
    }
  ]
}
