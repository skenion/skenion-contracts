{
  "schema": "skenion.runtime.operation",
  "schemaVersion": "0.1.0",
  "id": "op-paste-root",
  "kind": "pasteGraphFragment",
  "request": {
    "target": {
      "path": {
        "kind": "root"
      },
      "baseRevision": "root-rev-1"
    },
    "fragment": {
      "schema": "skenion.graph.fragment",
      "schemaVersion": "0.2.0",
      "id": "fragment-root",
      "nodes": [
        {
          "id": "value",
          "kind": "core.float",
          "kindVersion": "0.2.0",
          "params": {
            "value": 1
          },
          "ports": [
            {
              "id": "out",
              "direction": "output",
              "type": "number.float",
              "rate": "control"
            }
          ]
        }
      ],
      "edges": []
    },
    "placement": {
      "kind": "position",
      "x": 160,
      "y": 240
    },
    "options": {
      "idConflictPolicy": "remap",
      "outsideEndpointPolicy": "reject",
      "preserveRelativePositions": true
    }
  },
  "correlationId": "paste-root-1"
}
