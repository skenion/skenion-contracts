{
  "schema": "skenion.graph.patch",
  "schemaVersion": "0.1.0",
  "id": "replace_shader_interface",
  "baseRevision": "1",
  "clientId": "studio-local",
  "ops": [
    {
      "op": "replaceNodeInterface",
      "nodeId": "shader_1",
      "edgePolicy": "removeInvalidEdges",
      "ports": [
        {
          "id": "speed",
          "direction": "input",
          "label": "Speed",
          "type": {
            "flow": "value",
            "dataKind": "number.float",
            "range": {
              "min": 0,
              "max": 2,
              "step": 0.01
            }
          },
          "required": false,
          "default": 0.5,
          "activation": "latched"
        },
        {
          "id": "tint",
          "direction": "input",
          "label": "Tint",
          "type": {
            "flow": "value",
            "dataKind": "color"
          },
          "required": false,
          "default": [
            1,
            0.2,
            0.1,
            1
          ],
          "activation": "latched"
        },
        {
          "id": "out",
          "direction": "output",
          "label": "Out",
          "type": {
            "flow": "resource",
            "dataKind": "gpu.texture2d",
            "format": "rgba8unorm",
            "colorSpace": "srgb"
          }
        }
      ]
    }
  ]
}
