{
  "name": "@skenion/contracts",
  "version": "0.52.0",
  "description": "skenion contract schemas and validators",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "homepage": "https://github.com/skenion/skenion-contracts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skenion/skenion-contracts.git",
    "directory": "packages/ts"
  },
  "bugs": {
    "url": "https://github.com/skenion/skenion-contracts/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extension/v0.1/schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./graph/v0.1/schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./graph/v0.1/fragment-schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./node/v0.1/schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./node-catalog/v0.1/schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./shader/v0.1/interface-schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./shader/v0.1/diagnostic-schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./project/v0.1/schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./package/v0.1/schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./view/v0.1/schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./message/v0.1/value-schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./object-text/v0.1/parse-result-schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    },
    "./compatibility-matrix/v0.1/schema": {
      "types": "./dist/generated/schemas.d.ts",
      "import": "./dist/generated/schemas.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run clean && pnpm run generate && tsc -p tsconfig.json",
    "clean": "node scripts/clean-dist.mjs",
    "ci": "pnpm run build && pnpm run coverage",
    "coverage": "node --test --experimental-test-coverage --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=100 --test-coverage-include='dist/**/*.js' --test-coverage-exclude='dist/generated/**' test/*.test.mjs",
    "generate": "node scripts/generate-schemas.mjs",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
