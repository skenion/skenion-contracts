{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skenion.dev/schemas/graph/v0/graph.schema.json",
  "title": "Skenion Graph Document",
  "type": "object",
  "required": ["schema", "schemaVersion", "id", "revision", "nodes", "edges"],
  "properties": {
    "schema": {
      "const": "skenion.graph"
    },
    "schemaVersion": {
      "const": "0.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "kind", "params", "inputs", "outputs"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/port"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/port"
          }
        }
      },
      "additionalProperties": false
    },
    "port": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/dataType"
        },
        "required": {
          "type": "boolean"
        },
        "default": true
      },
      "additionalProperties": false
    },
    "dataType": {
      "type": "object",
      "required": ["flow", "kind"],
      "properties": {
        "flow": {
          "enum": ["constant", "sampled", "stream", "event", "resource"]
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "shape": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "channels": {
          "type": "integer",
          "minimum": 1
        },
        "sampleRate": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "unit": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": {
          "$ref": "#/$defs/portRef"
        },
        "to": {
          "$ref": "#/$defs/portRef"
        }
      },
      "additionalProperties": false
    },
    "portRef": {
      "type": "object",
      "required": ["node", "port"],
      "properties": {
        "node": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
