{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skenion.dev/schemas/graph/v0.1/patch-event.schema.json",
  "title": "Skenion Graph Patch Event v0.1",
  "type": "object",
  "required": [
    "schema",
    "schemaVersion",
    "id",
    "sequence",
    "kind",
    "patch",
    "inversePatch",
    "revisionBefore",
    "revisionAfter",
    "createdAt"
  ],
  "properties": {
    "schema": {
      "const": "skenion.graph.patch.event"
    },
    "schemaVersion": {
      "const": "0.1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "kind": {
      "enum": ["apply", "undo", "redo"]
    },
    "patch": {
      "$ref": "https://skenion.dev/schemas/graph/v0.1/patch.schema.json"
    },
    "inversePatch": {
      "$ref": "https://skenion.dev/schemas/graph/v0.1/patch.schema.json"
    },
    "revisionBefore": {
      "type": "string",
      "minLength": 1
    },
    "revisionAfter": {
      "type": "string",
      "minLength": 1
    },
    "clientId": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "subjectEventId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
