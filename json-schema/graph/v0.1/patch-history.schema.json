{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skenion.dev/schemas/graph/v0.1/patch-history.schema.json",
  "title": "Skenion Graph Patch History v0.1 (legacy import)",
  "description": "Frozen legacy graph patch history schema retained for old history import and migration fixtures only.",
  "type": "object",
  "required": [
    "schema",
    "schemaVersion",
    "events",
    "canUndo",
    "canRedo",
    "undoDepth",
    "redoDepth"
  ],
  "properties": {
    "schema": {
      "const": "skenion.graph.patch.history"
    },
    "schemaVersion": {
      "const": "0.1.0"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "https://skenion.dev/schemas/graph/v0.1/patch-event.schema.json"
      }
    },
    "canUndo": {
      "type": "boolean"
    },
    "canRedo": {
      "type": "boolean"
    },
    "undoDepth": {
      "type": "integer",
      "minimum": 0
    },
    "redoDepth": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
