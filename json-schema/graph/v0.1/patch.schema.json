{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skenion.dev/schemas/graph/v0.1/patch.schema.json",
  "title": "Skenion Graph Patch v0.1 (legacy import)",
  "description": "Frozen legacy graph patch schema retained for migration fixtures and old history import only. Active runtime mutation uses v0 RuntimeOperationEnvelope and graph v0.2 targets.",
  "type": "object",
  "required": ["schema", "schemaVersion", "id", "baseRevision", "ops"],
  "properties": {
    "schema": {
      "const": "skenion.graph.patch"
    },
    "schemaVersion": {
      "const": "0.1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "baseRevision": {
      "type": "string",
      "minLength": 1
    },
    "clientId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "ops": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/addNode"
          },
          {
            "$ref": "#/$defs/removeNode"
          },
          {
            "$ref": "#/$defs/replaceNode"
          },
          {
            "$ref": "#/$defs/setNodeParams"
          },
          {
            "$ref": "#/$defs/setNodeParam"
          },
          {
            "$ref": "#/$defs/addEdge"
          },
          {
            "$ref": "#/$defs/removeEdge"
          },
          {
            "$ref": "#/$defs/replaceNodeInterface"
          }
        ]
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "addNode": {
      "type": "object",
      "required": ["op", "node"],
      "properties": {
        "op": {
          "const": "addNode"
        },
        "node": {
          "$ref": "#/$defs/node"
        }
      },
      "additionalProperties": false
    },
    "removeNode": {
      "type": "object",
      "required": ["op", "nodeId"],
      "properties": {
        "op": {
          "const": "removeNode"
        },
        "nodeId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "replaceNode": {
      "type": "object",
      "required": ["op", "nodeId", "node", "edgePolicy"],
      "properties": {
        "op": {
          "const": "replaceNode"
        },
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "node": {
          "$ref": "#/$defs/node"
        },
        "edgePolicy": {
          "const": "removeInvalidEdges"
        }
      },
      "additionalProperties": false
    },
    "setNodeParams": {
      "type": "object",
      "required": ["op", "nodeId", "params"],
      "properties": {
        "op": {
          "const": "setNodeParams"
        },
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "setNodeParam": {
      "type": "object",
      "required": ["op", "nodeId", "key", "value"],
      "properties": {
        "op": {
          "const": "setNodeParam"
        },
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "value": true
      },
      "additionalProperties": false
    },
    "addEdge": {
      "type": "object",
      "required": ["op", "edge"],
      "properties": {
        "op": {
          "const": "addEdge"
        },
        "edge": {
          "$ref": "#/$defs/edge"
        }
      },
      "additionalProperties": false
    },
    "removeEdge": {
      "type": "object",
      "required": ["op", "edge"],
      "properties": {
        "op": {
          "const": "removeEdge"
        },
        "edge": {
          "$ref": "#/$defs/edge"
        }
      },
      "additionalProperties": false
    },
    "replaceNodeInterface": {
      "type": "object",
      "required": ["op", "nodeId", "ports", "edgePolicy"],
      "properties": {
        "op": {
          "const": "replaceNodeInterface"
        },
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/port"
          }
        },
        "edgePolicy": {
          "const": "removeInvalidEdges"
        }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": ["id", "kind", "kindVersion", "params", "ports"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "kindVersion": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/port"
          }
        }
      },
      "additionalProperties": false
    },
    "port": {
      "type": "object",
      "required": ["id", "direction", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "enum": ["input", "output"]
        },
        "label": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/dataType"
        },
        "required": {
          "type": "boolean"
        },
        "default": true,
        "activation": {
          "enum": ["trigger", "latched"]
        }
      },
      "additionalProperties": false
    },
    "dataType": {
      "type": "object",
      "required": ["flow", "dataKind"],
      "properties": {
        "flow": {
          "enum": ["value", "event", "signal", "stream", "resource"]
        },
        "dataKind": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string"
        },
        "range": {
          "type": "object",
          "properties": {
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            },
            "step": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "additionalProperties": false
        },
        "shape": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "channels": {
          "type": "integer",
          "minimum": 1
        },
        "sampleRate": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "format": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "colorSpace": {
          "type": "string"
        },
        "frameRate": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "alphaPolicy": {
          "enum": ["error", "white", "black", "luminance"]
        },
        "values": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              }
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": {
          "$ref": "#/$defs/portRef"
        },
        "to": {
          "$ref": "#/$defs/portRef"
        }
      },
      "additionalProperties": false
    },
    "portRef": {
      "type": "object",
      "required": ["node", "port"],
      "properties": {
        "node": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
