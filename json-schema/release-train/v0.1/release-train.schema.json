        "required": {
          "type": "boolean"
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "artifactId": {
          "type": "string",
          "minLength": 1
        },
        "evidenceUrl": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "studioPackageSmokeGateMap": {
      "type": "object",
      "required": ["aarch64-apple-darwin", "x86_64-apple-darwin", "x86_64-pc-windows-msvc", "aarch64-pc-windows-msvc", "x86_64-unknown-linux-gnu", "aarch64-unknown-linux-gnu"],
      "properties": {
        "aarch64-apple-darwin": {
          "$ref": "#/$defs/studioPackageSmokeGate"
        },
        "x86_64-apple-darwin": {
          "$ref": "#/$defs/studioPackageSmokeGate"
        },
        "x86_64-pc-windows-msvc": {
          "$ref": "#/$defs/studioPackageSmokeGate"
        },
        "aarch64-pc-windows-msvc": {
          "$ref": "#/$defs/studioPackageSmokeGate"
        },
        "x86_64-unknown-linux-gnu": {
          "$ref": "#/$defs/studioPackageSmokeGate"
        },
        "aarch64-unknown-linux-gnu": {
          "$ref": "#/$defs/studioPackageSmokeGate"
        }
      },
      "additionalProperties": false
    },
    "studioPackageSmokeGate": {
      "type": "object",
      "required": ["id", "status", "required", "target", "desktopPackageArtifactId", "runtimeSidecarArtifactId"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/gateStatus"
        },
        "required": {
          "type": "boolean"
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "desktopPackageArtifactId": {
          "type": "string",
          "minLength": 1
        },
        "runtimeSidecarArtifactId": {
          "type": "string",
          "minLength": 1
        },
        "evidenceUrl": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "examplesConformanceGate": {
      "type": "object",
      "required": ["id", "status", "required", "repository", "ref", "version"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/gateStatus"
        },
        "required": {
          "type": "boolean"
        },
        "repository": {
          "$ref": "#/$defs/repository"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "$ref": "#/$defs/version"
        },
        "evidenceUrl": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "docsPagesDeploymentGate": {
      "type": "object",
      "required": ["id", "status", "required", "manualVersion", "manualPath", "pagesUrl"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/gateStatus"
        },
        "required": {
          "type": "boolean"
        },
        "manualVersion": {
          "$ref": "#/$defs/version"
        },
        "manualPath": {
          "type": "string",
          "pattern": "^/manual/[0-9]+\\.[0-9]+/$"
        },
        "pagesUrl": {
          "type": "string",
          "pattern": "^https://skenion\\.github\\.io/skenion-docs/manual/[0-9]+\\.[0-9]+/$"
        },
        "evidenceUrl": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "gateStatus": {
      "enum": ["pending", "passed", "failed", "waived"]
    },
    "target": {
      "enum": ["aarch64-apple-darwin", "x86_64-apple-darwin", "x86_64-pc-windows-msvc", "aarch64-pc-windows-msvc", "x86_64-unknown-linux-gnu", "aarch64-unknown-linux-gnu"]
    },
    "repository": {
      "type": "string",
      "pattern": "^skenion/[A-Za-z0-9_.-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    }
  }
