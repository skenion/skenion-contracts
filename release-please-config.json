{
  "release-type": "simple",
  "packages": {
    ".": {
      "package-name": "skenion-contracts",
      "include-component-in-tag": false,
      "include-v-in-tag": true,
      "extra-files": [
        {
          "type": "json",
          "path": "packages/ts/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "packages/rust/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "toml",
          "path": "packages/rust/Cargo.lock",
          "jsonpath": "$.package[?(@.name.value=='skenion-contracts')].version"
        }
      ]
    }
  }
}
